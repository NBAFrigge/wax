[Unit]
Description=Wax clipboard manager daemon
Documentation=https://github.com/NBAFrigge/wax
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/wax-daemon
Restart=on-failure
RestartSec=3

# Logging via systemd journal: journalctl --user -u wax -f
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=graphical-session.target
